__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.python-version
.env
env/
venv/
.venv/

# ==========================================
# DISTRIBUTION & PACKAGING
# ==========================================
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ==========================================
# IDEs, LINTERS & TOOLING
# ==========================================
.ruff_cache/
.vscode/
.idea/
Makefile

# ==========================================
# JUPYTER
# ==========================================
.ipynb
docs/guide/interactive/_templates/_template.ipynb
!docs/guide/interactive/create_backing_track.ipynb
!docs/guide/interactive/extract_drums.ipynb
!docs/guide/interactive/measure_tempo.ipynb
!docs/guide/interactive/transcribe.ipynb

.ipynb_checkpoints/

# ==========================================
